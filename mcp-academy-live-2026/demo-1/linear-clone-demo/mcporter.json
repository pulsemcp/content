{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "pulse-notify-staging": {
      "command": "npx",
      "args": ["-y", "pulsemcp-cms-admin-mcp-server@latest"],
      "env": {
        "PULSEMCP_ADMIN_API_KEY": "${PULSEMCP_STAGING_ADMIN_READ_WRITE_API_KEY}",
        "PULSEMCP_ADMIN_API_URL": "https://admin.staging.pulsemcp.com",
        "TOOL_GROUPS": "notifications"
      }
    },
    "postgres-pulsemcp-staging": {
      "command": "uvx",
      "args": ["--from", "postgres-mcp==0.3.0", "postgres-mcp", "--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "postgresql://${POSTGRES_PULSEMCP_STAGING_USERNAME}:${POSTGRES_PULSEMCP_STAGING_PASSWORD}@pulsemcp-staging-do-user-10365419-0.g.db.ondigitalocean.com:25060/defaultdb?sslmode=require"
      }
    },
    "gmail-pulsemcp-readonly": {
      "command": "npx",
      "args": ["-y", "gmail-workspace-mcp-server@latest"],
      "env": {
        "GMAIL_OAUTH_CLIENT_ID": "${GMAIL_PULSEMCP_OAUTH_CLIENT_ID}",
        "GMAIL_OAUTH_CLIENT_SECRET": "${GMAIL_PULSEMCP_OAUTH_CLIENT_SECRET}",
        "GMAIL_OAUTH_REFRESH_TOKEN": "${GMAIL_PULSEMCP_OAUTH_REFRESH_TOKEN}",
        "GMAIL_ENABLED_TOOLGROUPS": "readonly",
        "ELICITATION_ENABLED": "true",
        "ELICITATION_REQUEST_URL": "https://ao.pulsemcp.com/api/v1/elicitations",
        "ELICITATION_POLL_URL": "https://ao.pulsemcp.com/api/v1/elicitations"
      }
    },
    "gmail-tadas-readwrite-external": {
      "command": "npx",
      "args": ["-y", "gmail-workspace-mcp-server@latest"],
      "env": {
        "GMAIL_SERVICE_ACCOUNT_CLIENT_EMAIL": "${GMAIL_TADAS_SERVICE_ACCOUNT_CLIENT_EMAIL}",
        "GMAIL_SERVICE_ACCOUNT_PRIVATE_KEY": "${GMAIL_TADAS_SERVICE_ACCOUNT_PRIVATE_KEY}",
        "GMAIL_IMPERSONATE_EMAIL": "tadas@tadasant.com",
        "GMAIL_ENABLED_TOOLGROUPS": "readwrite_external",
        "ELICITATION_ENABLED": "true",
        "ELICITATION_REQUEST_URL": "https://ao.pulsemcp.com/api/v1/elicitations",
        "ELICITATION_POLL_URL": "https://ao.pulsemcp.com/api/v1/elicitations"
      }
    },
    "slack-workspace": {
      "command": "npx",
      "args": ["-y", "slack-workspace-mcp-server@latest"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}"
      }
    },
    "pulse-official-queue-rw": {
      "command": "npx",
      "args": ["-y", "pulsemcp-cms-admin-mcp-server@latest"],
      "env": {
        "PULSEMCP_ADMIN_API_KEY": "${PULSEMCP_ADMIN_READ_WRITE_API_KEY}",
        "TOOL_GROUPS": "official_queue"
      }
    },
    "pulse-submit-queue-rw-staging": {
      "command": "npx",
      "args": ["-y", "pulsemcp-cms-admin-mcp-server@latest"],
      "env": {
        "PULSEMCP_ADMIN_API_KEY": "${PULSEMCP_STAGING_ADMIN_READ_WRITE_API_KEY}",
        "PULSEMCP_ADMIN_API_URL": "https://admin.staging.pulsemcp.com",
        "TOOL_GROUPS": "server_directory"
      }
    },
    "pulse-mirror-mgmt-rw": {
      "command": "npx",
      "args": ["-y", "pulsemcp-cms-admin-mcp-server@latest"],
      "env": {
        "PULSEMCP_ADMIN_API_KEY": "${PULSEMCP_ADMIN_READ_WRITE_API_KEY}",
        "TOOL_GROUPS": "mcp_servers,mcp_jsons,tenants,official_mirrors,unofficial_mirrors"
      }
    },
    "pulse-discovery-rw": {
      "command": "npx",
      "args": ["-y", "pulsemcp-cms-admin-mcp-server@latest"],
      "env": {
        "PULSEMCP_ADMIN_API_KEY": "${PULSEMCP_ADMIN_READ_WRITE_API_KEY}",
        "TOOL_GROUPS": "discovered_urls"
      }
    },
    "google-calendar-tadas-readwrite": {
      "command": "npx",
      "args": ["-y", "google-calendar-workspace-mcp-server@latest"],
      "env": {
        "GCAL_SERVICE_ACCOUNT_CLIENT_EMAIL": "${GOOGLE_CALENDAR_TADAS_SERVICE_ACCOUNT_CLIENT_EMAIL}",
        "GCAL_SERVICE_ACCOUNT_PRIVATE_KEY": "${GOOGLE_CALENDAR_TADAS_SERVICE_ACCOUNT_PRIVATE_KEY}",
        "GCAL_IMPERSONATE_EMAIL": "tadas@tadasant.com",
        "ENABLED_TOOLGROUPS": "readwrite"
      }
    }
  }
}
